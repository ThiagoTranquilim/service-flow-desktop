                    xmlns:vm="clr-namespace:Service_Flow_Desktop.ViewModels"
                    xmlns:view="clr-namespace:Service_Flow_Desktop.Views">

    <DataTemplate DataType="{x:Type vm:ClientesViewModel}">
        <view:ClientesView />
    </DataTemplate>

    <DataTemplate DataType="{x:Type vm:ServicosViewModel}">
        <view:ServicosView />
    </DataTemplate>

    <DataTemplate DataType="{x:Type vm:OrdensServicoViewModel}">
        <view:OrdensServicoView />
    </DataTemplate>

    <DataTemplate DataType="{x:Type vm:OrdemServicoFormViewModel}">
        <view:OrdemServicoFormView />
    </DataTemplate>

</ResourceDictionary>