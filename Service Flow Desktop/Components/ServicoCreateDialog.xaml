<UserControl x:Class="Service_Flow_Desktop.Components.ServicoCreateDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Service_Flow_Desktop.Components"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Border Background="#80000000">
        <Border
    Width="340"
    Padding="20"
    Background="#272B2F"
    HorizontalAlignment="Center"
    VerticalAlignment="Center">

            <StackPanel>
                <TextBlock
                    Text="Novo Serviço"
                    FontSize="22"
                    FontWeight="Bold" />
                
                <TextBlock Text="Nome" />
                <TextBox Text="{Binding NovoServicoNome}" />

                <TextBlock Text="Descrição" />
                <TextBox Text="{Binding NovoServicoDescricao}" />

                <TextBlock Text="Valor Base" />
                <TextBox Text="{Binding NovoServicoValorBase}" />

                <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                    <Button
                Content="Salvar"
                Command="{Binding SalvarNovoServicoCommand}" />

                    <Button
                Content="Cancelar"
                Command="{Binding CancelarNovoServicoCommand}"
                Margin="8,0,0,0" />
                </StackPanel>
            </StackPanel>
        </Border>
    </Border>
</UserControl>
