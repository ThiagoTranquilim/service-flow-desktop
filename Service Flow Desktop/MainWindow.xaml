<Window x:Class="Service_Flow_Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:menu="clr-namespace:Service_Flow_Desktop.Utilities"
        Title="Service Flow"
        Height="600"
        Width="850"
        AllowsTransparency="True"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        Background="Transparent">

    <Grid>
        <Border Background="#212529"
                CornerRadius="20" />

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="228" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Menu lateral -->
            <Grid Grid.Column="0">
                <Border Background="#272B2F"
                        CornerRadius="20,0,0,20" />

                <StackPanel Width="228"
                            Margin="0,40,0,0">

                    <menu:Btn Style="{StaticResource BtnStyle}">
                        <StackPanel Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <Image Source="/images/img_home.png"
                                   Style="{StaticResource Image_Style}" />

                            <TextBlock Text="Home"
                                       Style="{StaticResource Text_Style}" />
                        </StackPanel>
                    </menu:Btn>

                    <menu:Btn Style="{StaticResource BtnStyle}"
                              Command="{Binding ShowOrdensServicoCommand}">
                        <StackPanel Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <Image Source="/Images/img_order.png"
                                   Style="{StaticResource Image_Style}" />

                            <TextBlock Text="Ordens"
                                       Style="{StaticResource Text_Style}" />
                        </StackPanel>
                    </menu:Btn>

                    <menu:Btn Style="{StaticResource BtnStyle}"
                              Command="{Binding ShowClientesCommand}">
                        <StackPanel Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <Image Source="/Images/img_customer.png"
                                   Style="{StaticResource Image_Style}" />

                            <TextBlock Text="Clientes"
                                       Style="{StaticResource Text_Style}" />
                        </StackPanel>
                    </menu:Btn>

                    <menu:Btn Style="{StaticResource BtnStyle}"
                              Command="{Binding ShowServicosCommand}">
                        <StackPanel Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <Image Source="/Images/img_product.png"
                                   Style="{StaticResource Image_Style}" />

                            <TextBlock Text="Serviços"
                                       Style="{StaticResource Text_Style}" />
                        </StackPanel>
                    </menu:Btn>

                </StackPanel>
            </Grid>

            <ContentControl Grid.Column="1"
                            Content="{Binding CurrentViewModel}" />
        </Grid>

        <Button x:Name="CloseApp"
                Style="{StaticResource ExitApp}"
                Click="CloseApp_Click" />
    </Grid>
</Window>